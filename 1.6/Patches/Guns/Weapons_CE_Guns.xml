        <XPath>/Defs/ThingDef[defName="CE_Gun_Crossbow"]/costList/WoodLog</XPath>
    </Operation>
    <Operation Class="PatchOperationAdd">
        <XPath>/Defs/ThingDef[defName="CE_Gun_Crossbow"]</XPath>
        <Value>
					<stuffCategories>
						<li>EW2_RawWoody</li>
					</stuffCategories>
					<costStuffCount>40</costStuffCount>
