<?xml version="1.0" encoding="utf-8"?>
<Patch>
<!-- MakeAmmo_CrossbowBolt_Stone -->
    <Operation Class="PatchOperationAdd">
        <XPath>/Defs/RecipeDef[defName="MakeAmmo_CrossbowBolt_Stone"]/ingredients/li[filter/thingDefs/li="WoodLog"]/filter</XPath>
        <Value>
                <categories>
                    <li>EW2_WoodLog</li>
                </categories>
        </Value>
    </Operation>
    <Operation Class="PatchOperationAdd">
        <XPath>/Defs/RecipeDef[defName="MakeAmmo_CrossbowBolt_Stone"]/fixedIngredientFilter</XPath>
        <Value>
                <categories>
                    <li>EW2_WoodLog</li>
                </categories>
        </Value>
    </Operation>

