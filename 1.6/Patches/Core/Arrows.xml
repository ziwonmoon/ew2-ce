<?xml version="1.0" encoding="utf-8"?>
<Patch>
<!-- MakeAmmo_Arrow_Stone -->
    <Operation Class="PatchOperationAdd">
        <XPath>/Defs/RecipeDef[defName="MakeAmmo_Arrow_Stone"]/ingredients/li[filter/thingDefs/li="WoodLog"]/filter</XPath>
        <Value>
                <categories>
                    <li>EW2_WoodLog</li>
                </categories>
        </Value>
    </Operation>
