        <XPath>/Defs/ThingDef[defName="Gun_Revolver"]/costList/WoodLog</XPath>
    </Operation>
    <Operation Class="PatchOperationAdd">
        <XPath>/Defs/ThingDef[defName="Gun_Revolver"]</XPath>
